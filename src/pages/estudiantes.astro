---
import Layout from '../layouts/Layout.astro';
import EstudiantesPage from '../components/EstudiantesPage';
---

<Layout
  title="Estudiantes — Galería 3D"
  description="Perfiles y habilidades de los estudiantes de Estudio de Creación Digital 4"
>
  <header class="page-header">
    <div class="page-header-inner">
      <a href="/" class="page-back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M19 12H5M12 5l-7 7 7 7"/>
        </svg>
        Galería
      </a>
      <div class="page-header-title-wrap">
        <h1 class="page-title">Estudiantes</h1>
        <span class="page-title-sub">Habilidades y modelos</span>
      </div>
    </div>
  </header>

  <main class="estudiantes-main">
    <EstudiantesPage client:load />
  </main>

  <footer>
    <p>© 2026 Estudio de Creación Digital 4 — Universidad El Bosque</p>
    <p>GLB · PBR · WebXR</p>
  </footer>
</Layout>
