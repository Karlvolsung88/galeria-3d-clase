---
import UserMenu from '../components/UserMenu';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Galería 3D — Estudio de Creación Digital 4',
  description = 'Galería interactiva de modelos 3D creados por estudiantes de Estudio de Creación Digital 4'
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="generator" content={Astro.generator} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />

  <!-- View Transitions — navegación SPA sin recargas completas -->
  <ClientRouter />

  <!-- Preconnect to critical origins -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://lvvleptxcddwhgmvxjdq.supabase.co" />
  <link rel="preconnect" href="https://ajax.googleapis.com" />

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet" />

  <!-- model-viewer (async to not block rendering) -->
  <script type="module" async src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.4.0/model-viewer.min.js"></script>

  <title>{title}</title>
</head>
<body>
  <div id="top-bar">
    <a href="/galeria-3d-clase/" class="topbar-brand">
      <span class="topbar-brand-dot">✦</span>
      <span>Galería 3D</span>
    </a>
    <nav class="topbar-nav">
      <a href="/galeria-3d-clase/" class="topbar-nav-link">Galería</a>
      <a href="/galeria-3d-clase/estudiantes" class="topbar-nav-link">Estudiantes</a>
    </nav>
    <div class="topbar-right">
      <UserMenu client:load />
    </div>
  </div>
  <slot />
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
