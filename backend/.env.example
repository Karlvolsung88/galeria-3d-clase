# === TEMPLATE — copiar a .env y rellenar con valores reales ===
# Para dev local:   DB_NAME=galeria_3d_local, user local
# Para prod:        las credenciales reales viven en el droplet (/var/www/galeria-api/.env)

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=galeria_3d_local
DB_USER=galeria_local
DB_PASS=***

# JWT — usar un secret DISTINTO al de prod para que los tokens no sean intercambiables
JWT_SECRET=cambiar-en-cada-entorno

# DigitalOcean Spaces (compartido entre dev y prod si se usa el mismo bucket)
SPACES_KEY=***
SPACES_SECRET=***
SPACES_BUCKET=galeria-3d-files
SPACES_REGION=nyc3
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
SPACES_CDN=https://galeria-3d-files.nyc3.cdn.digitaloceanspaces.com

# Server
PORT=3000
NODE_ENV=development
